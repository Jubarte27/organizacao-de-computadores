- LUI:
    - opcode: 0110111
    - ALUop: 11
    - ALUcontrol: 1111
    - controle:
        - monociclo: 11011000
        - multiciclo: opcode 0110111 leva a linha 0x370
            - Passo 1: 0110111 0 -> 1
            - Passo 2: 0110111 1 -> 10
            - Passo 3: 0110111 10 -> 7
            - Passo 4: 0110111 7 -> 0
        - pipeline: 10000111
- SLLI:
    - opcode: 0010011
    - funct3: 001
    - funct7: 0000000
    - ALUop: 10
    - ALUcontrol: 0101
    - controle:
        - monociclo: 11010000
        - multiciclo: opcode 0010011 leva a linha 0x130
            - Passo 1: 0010011 0 -> 1
            - Passo 2: 0010011 1 -> 9
            - Passo 3: 0010011 9 -> 7
            - Passo 4: 0010011 7 -> 0
        - pipeline: 10000110

